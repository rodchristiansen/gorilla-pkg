# Function to generate a valid directory ID and Name
def generate_directory_id_name(part):
    # Replace invalid characters with underscores for IDs
    sanitized_part = part.replace(' ', '_').replace(':', '').replace('\\', '').replace('/', '')
    dir_id = f"dir_{sanitized_part}"
    # Remove invalid characters for Names
    dir_name = part.replace(":", "").replace("\\", "").replace("/", "")
    
    # If the name is empty (like for 'C:'), use a placeholder
    if not dir_name:
        dir_name = "ROOT"
        
    return dir_id, dir_name

# Function to find the matching standard directory
def find_standard_directory(install_path, standard_directories):
    normalized_install_path = os.path.normpath(install_path)
    for standard_path, directory_id in standard_directories.items():
        normalized_standard_path = os.path.normpath(standard_path)
        if normalized_install_path.startswith(normalized_standard_path):
            # Return the directory_id and the remaining part of the path after the standard directory
            remaining_path = normalized_install_path[len(normalized_standard_path):].lstrip(os.sep)
            return directory_id, remaining_path
    return None, install_path  # No standard directory found, return the full path as is

# Function to generate WiX XML files, including embedding PowerShell scripts as binaries
def generate_wix_files(project_dir, config):
    NS_WIX = "http://wixtoolset.org/schemas/v4/wxs"
    install_path = config['install_path'].replace("[username]", os.getlogin())
    standard_directories = get_standard_directories()
    directory_id, remaining_path = find_standard_directory(install_path, standard_directories)

    wix = etree.Element("Wix", nsmap={None: NS_WIX})
    package = etree.SubElement(wix, "Package", 
                               Name=config['product']['name'], 
                               Version=parse_version(config['product']['version']),
                               Manufacturer=config['product']['manufacturer'], 
                               UpgradeCode=generate_guids(config['product']['identifier'])[1],
                               InstallerVersion="500", 
                               Compressed="yes")
    etree.SubElement(package, "Media", Id="1", Cabinet="product.cab", EmbedCab="yes")

    # Define the directory structure
    if directory_id:
        install_folder = etree.SubElement(package, "StandardDirectory", Id=directory_id)
        current_dir = install_folder
        for part in Path(remaining_path).parts:
            dir_id, dir_name = generate_directory_id_name(part)
            current_dir = etree.SubElement(current_dir, "Directory", Id=dir_id, Name=dir_name)
    else:
        install_folder = etree.SubElement(package, "StandardDirectory", Id="ProgramFilesFolder")
        current_dir = etree.SubElement(install_folder, "Directory", Id="INSTALLFOLDER", Name=config['product']['manufacturer'] + " " + config['product']['name'])
        for part in Path(install_path).parts:
            dir_id, dir_name = generate_directory_id_name(part)
            current_dir = etree.SubElement(current_dir, "Directory", Id=dir_id, Name=dir_name)

    # Define the main feature
    feature = etree.SubElement(package, "Feature", Id="MainFeature", Title="Main Feature", Level="1")

    # Always create InstallExecuteSequence
    install_execute_sequence = etree.SubElement(package, "InstallExecuteSequence")

    # Handle scripts (if any)
    actions = get_scripts(project_dir)
    fragment = etree.SubElement(wix, "Fragment")
    
    if actions:
        for script_type, script_path in actions.items():
            # Read the script content
            with open(script_path, 'rb') as script_file:
                script_content = script_file.read()
            
            # Create a Binary element with the script content
            binary_id = f"Bin_{script_type.capitalize()}"
            binary_element = etree.SubElement(fragment, "Binary", Id=binary_id)
            binary_element.set("SourceFile", script_path)  # Reference the script file

            # Define the custom action to execute the script
            run_action_id = f"Run{script_type.capitalize()}"
            etree.SubElement(fragment, "CustomAction", Id=run_action_id, BinaryRef=binary_id,
                             Execute="deferred", Return="check", Impersonate="no")
            
            # Add the custom action to the InstallExecuteSequence
            if script_type == 'preinstall':
                etree.SubElement(install_execute_sequence, "Custom", Action=run_action_id, Before="InstallFiles")
            elif script_type == 'postinstall':
                etree.SubElement(install_execute_sequence, "Custom", Action=run_action_id, After="InstallFiles")
    else:
        # Define a no-op CustomAction if no scripts are found
        no_op_action_id = "NoOpAction"
        etree.SubElement(fragment, "CustomAction", Id=no_op_action_id, Execute="none")
        etree.SubElement(install_execute_sequence, "Custom", Action=no_op_action_id, Before="InstallFinalize")

    # Add payload files to the package
    payload_dir = Path(project_dir) / "payload"
    for file_path in payload_dir.rglob('*'):
        if file_path.is_file():
            relative_path = file_path.relative_to(payload_dir)
            dir_element = current_dir
            for part in relative_path.parent.parts:
                dir_id, dir_name = generate_directory_id_name(part)
                existing_dir = dir_element.find(f"./Directory[@Id='{dir_id}']")
                if existing_dir is None:
                    dir_element = etree.SubElement(dir_element, "Directory", Id=dir_id, Name=dir_name)
                else:
                    dir_element = existing_dir
            component_id = f"Component_{uuid.uuid4().hex}"
            component = etree.SubElement(dir_element, "Component", Id=component_id, Guid=str(uuid.uuid4()))
            etree.SubElement(component, "File", Id=f"File_{uuid.uuid4().hex}", Source=str(file_path), KeyPath="yes")
            etree.SubElement(feature, "ComponentRef", Id=component_id)

    # Finalize XML and save
    xml_str = etree.tostring(wix, pretty_print=True, xml_declaration=True, encoding='UTF-8')
    output_path = Path(project_dir) / "src" / "Package.wxs"
    output_path.parent.mkdir(parents=True, exist_ok=True)  # Ensure directory exists
    with open(output_path, 'wb') as file:
        file.write(xml_str)
    
    log("Generated XML:")
    log(xml_str.decode())
    return output_path

# Function to run a subprocess and check for errors
def run_command(command, quiet=False, verbose=False):
    if verbose:
        command += " -v"
    log(f"Executing command: {command}")
    result = subprocess.run(command, shell=True, capture_output=True, text=True)
    if result.returncode != 0:
        log(f"Command failed with return code {result.returncode}: {result.stderr}", error=True)
        if not quiet:
            log(f"Output: {result.stdout}", error=True)
        return False, result.stderr
    if not quiet:
        log(result.stdout)
    return True, result.stdout

def verify_wxs_files(project_dir):
    src_dir = Path(project_dir) / "src"
    package_wxs_path = src_dir / "Package.wxs"
    
    try:
        with open(package_wxs_path, 'rb') as file:
            content = file.read()

        # Use lxml to parse the XML and verify the structure
        tree = etree.fromstring(content)
        NS_WIX = "http://wixtoolset.org/schemas/v4/wxs"
        
        # Verify essential elements exist
        required_tags = [
            f"{{{NS_WIX}}}Package",
            f"{{{NS_WIX}}}Directory",
            f"{{{NS_WIX}}}Component",
            f"{{{NS_WIX}}}ComponentRef",
            f"{{{NS_WIX}}}CustomAction",
            f"{{{NS_WIX}}}InstallExecuteSequence",
            f"{{{NS_WIX}}}Binary"
        ]

        missing_tags = []
        for tag in required_tags:
            if not tree.findall(f".//{tag}"):
                missing_tags.append(tag)

        if missing_tags:
            log(f"Package.wxs is missing necessary tags: {missing_tags}", error=True)
            return False

    except Exception as e:
        log(f"Error reading or parsing {package_wxs_path}: {str(e)}", error=True)
        return False

    log("WXS files verification passed.")
    return True
    
# Function to run SignTool if 'identity' key is present
def sign_msi(msi_file, identity):
    log(f"Signing MSI package {msi_file} with identity {identity}")
    sign_command = f'signtool sign /n "{identity}" /fd SHA256 /tr http://timestamp.digicert.com /td SHA256 "{msi_file}"'
    success, output = run_command(sign_command)
    if not success:
        log("Failed to sign MSI package.", error=True)
        return False
    log("MSI package signed successfully.")
    return True

# Update the build_msi function to include verbose logging and correct embedding
def build_msi(project_dir, wix_path, output_dir=None):
    src_dir = Path(project_dir) / "src"
    
    # Use 'build' folder as default output directory unless specified
    if output_dir is None:
        output_dir = Path(project_dir) / "build"
    else:
        output_dir = Path(output_dir)
    
    output_dir.mkdir(exist_ok=True)
    
    wix_exe = Path(wix_path) / "wix.exe"
    package_wix_file = src_dir / "Package.wxs"
    msi_file_name = f"{read_build_info(project_dir)['product']['name']}.msi"
    msi_file = output_dir / msi_file_name
    
    # Verbose command to use Package.wxs for building MSI
    command = f'"{wix_exe}" build -v -out "{msi_file}" "{package_wix_file}"'
    success, output = run_command(command)
    if not success:
        log("Failed to create MSI package.", error=True)
        return
    
    log(f"MSI package created successfully at {msi_file}.")
    
    # Check if 'identity' key is present in build-info.yaml for signing
    config = read_build_info(project_dir)
    if 'identity' in config:
        if not sign_msi(msi_file, config['identity']):
            log("MSI signing process failed.", error=True)
            return
    
